{
  "config": {
    "wide_screen_mode": true
  },
  "header": {
    "title": {
      "tag": "plain_text",
      "content": "📊 {{project_name}} 项目概览 · {{date}}"
    },
    "template": "indigo"
  },
  "elements": [
    {
      "tag": "div",
      "text": {
        "tag": "lark_md",
        "content": "**待办状态**\n📋 待处理：{{pending_count}} 项\n🔄 进行中：{{in_progress_count}} 项\n⚠️ 已过期：{{overdue_count}} 项"
      }
    },
    {
      "tag": "hr"
    },
    {
      "tag": "div",
      "text": {
        "tag": "lark_md",
        "content": "**里程碑**\n{{milestone_summary}}"
      }
    },
    {
      "tag": "hr"
    },
    {
      "tag": "action",
      "actions": [
        {
          "tag": "button",
          "text": {
            "tag": "plain_text",
            "content": "🔍 查看详情"
          },
          "type": "link",
          "url": "{{base_url}}"
        }
      ]
    },
    {
      "tag": "note",
      "elements": [
        {
          "tag": "plain_text",
          "content": "Smart-PMO · 每日自动推送"
        }
      ]
    }
  ]
}
